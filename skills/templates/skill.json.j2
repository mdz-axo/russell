{
  "$schema": "https://raw.githubusercontent.com/hashgraph-online/registry-broker-skills/main/schemas/skill.schema.json",
  "name": "{{ id }}",
  "version": "{{ version | default('0.1.0') }}",
  "description": "{{ description }}",
  "author": "{{ author | default('Russell (Jack the Nurse)') }}",
  "license": "{{ license | default('MIT OR Apache-2.0') }}",
  "homepage": "https://github.com/mdz-axolotl/russell",
  "tags": [{% for tag in tags %}"{{ tag }}"{% if not loop.last %}, {% endif %}{% endfor %}, "russell-replicant"],
  "languages": ["bash", "shell"],
  "repo": "https://github.com/mdz-axolotl/russell",
  "permissions": {
    "shell": {
      "enabled": {% if permissions.shell %}true{% else %}false{% endif %},
      "commands": [{% for cmd in shell_commands %}"{{ cmd }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    },
    "network": {
      "enabled": {% if permissions.network %}true{% else %}false{% endif %},
      "endpoints": [{% for endpoint in network_endpoints %}"{{ endpoint }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    }
  },
  "config": {
{% for key, value in config.items() %}
    "{{ key }}": {
      "type": "{{ value.type | default('string') }}",
      "required": {% if value.required %}true{% else %}false{% endif %}{% if value.default %},
      "default": "{{ value.default }}"{% endif %}{% if value.description %},
      "description": "{{ value.description }}"{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  },
  "entryPoint": {
    "type": "{{ entry_point.type | default('shell') }}",
    "path": "{{ entry_point.path | default('./scripts/probe.sh') }}"
  },
  "triggers": {
    "schedule": "{{ triggers.schedule | default('*/5 * * * *') }}"
  },
  "replicant": {
    "id": "russell",
    "visibility": "{{ visibility | default('public') }}",
    "artifact_type": "semantic_memory",
    "episodic_memory": false
  },
  "stats": {
    "probes": {{ probes | length }},
    "interventions": {{ interventions | length }},
    "symptoms": {{ symptoms | length }}
  }
}
