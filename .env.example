# Russell operator environment template.
#
# Copy this to ~/.config/harness/russell.env and fill in your keys.
# Russell's install.sh does that automatically on first run.
#
# Precedence (first wins, set value wins over file):
#   1. process env (set by shell or systemd)
#   2. ~/.config/harness/russell.env
#   3. <repo>/.env (dev convenience)
#   4. ./.env (ad-hoc)

# ---- LLM routing ----------------------------------------------------

# OpenRouter API key. If unset, `russell jack` falls back to offline
# rule-based summary. You can get one at https://openrouter.ai/.
OPENROUTER_API_KEY=

# Model identifier. Default is Kimi K2.5 (Moonshot's frontier open-weight
# reasoning model). Any OpenAI-compatible model ID OpenRouter exposes
# works.
RUSSELL_DOCTOR_MODEL=moonshotai/kimi-k2.5

# Backend: openrouter | ollama | mock | offline.
# Default = openrouter if OPENROUTER_API_KEY is set, else offline.
#RUSSELL_DOCTOR_BACKEND=openrouter

# Override the HTTP base URL. Leave unset unless you're testing.
#RUSSELL_DOCTOR_BASE_URL=https://openrouter.ai/api/v1

# ---- Observability --------------------------------------------------

# Tracing filter. `russell=info,warn` is a reasonable default.
#RUSSELL_LOG=russell=info,warn

# ---- Safety ---------------------------------------------------------

# Set to 1 to route every mutating call through the dry-run path.
# MVP has no mutating calls; this is a forward-looking knob.
#RUSSELL_DRY_RUN=0
