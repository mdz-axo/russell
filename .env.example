# Russell operator environment template.
#
# Copy this to ~/.config/harness/russell.env and fill in your keys.
# Russell's install.sh does that automatically on first run.
#
# Precedence (first wins, set value wins over file):
#   1. process env (set by shell or systemd)
#   2. ~/.config/harness/russell.env
#   3. <repo>/.env (dev convenience)
#   4. ./.env (ad-hoc)

# ---- LLM routing ----------------------------------------------------

# Backend: ollama | openrouter | mock | offline.
# Default is ollama (local). Russell checks for a running Ollama and
# auto-starts it via systemctl if needed.
RUSSELL_DOCTOR_BACKEND=ollama

# Model identifier. Default is deepseekv4pro. Any model available in
# the configured backend works.
RUSSELL_DOCTOR_MODEL=deepseekv4pro

# OpenRouter API key — only needed if you set RUSSELL_DOCTOR_BACKEND=openrouter.
# Get one at https://openrouter.ai/.
#OPENROUTER_API_KEY=

# Override the HTTP base URL. Leave unset unless you're testing.
# Ollama default: http://127.0.0.1:11434/v1
#RUSSELL_DOCTOR_BASE_URL=http://127.0.0.1:11434/v1

# ---- Observability --------------------------------------------------

# Tracing filter. `russell=info,warn` is a reasonable default.
#RUSSELL_LOG=russell=info,warn

# ---- Safety ---------------------------------------------------------

# Set to 1 to route every mutating call through the dry-run path.
# MVP has no mutating calls; this is a forward-looking knob.
#RUSSELL_DRY_RUN=0
